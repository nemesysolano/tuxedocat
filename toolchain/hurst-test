def var_lagged_diffs(ts):
     ts_len = len(ts)
     # Dynamically set the max lag. 
     # Limit it to 100, but NEVER let it exceed half the length of the time series.
     
     max_lag = min(100, ts_len // 2)
     # Safety check for very short time series
     if max_lag < 2:
       raise ValueError("Time series is too short to compute Hurst exponent.")
     
     lags = range(2, max_lag)
     tau = [std(subtract(ts[lag:], ts[:-lag])) for lag in lags]
     return tau

def hurst(ts):
    """Returns the Hurst Exponent of the time series vector ts"""
    ts_len = len(ts)
    
    # Dynamically set the max lag. 
    # Limit it to 100, but NEVER let it exceed half the length of the time series.
    max_lag = min(100, ts_len // 2)
    
    # Safety check for very short time series
    if max_lag < 2:
        raise ValueError("Time series is too short to compute Hurst exponent.")
        
    lags = range(2, max_lag)
    
    # Calculate the array of the variances of the lagged differences
    tau = [sqrt(std(subtract(ts[lag:], ts[:-lag]))) for lag in lags]
    
    # Use a linear fit to estimate the Hurst Exponent
    poly = polyfit(log(lags), log(tau), 1)
    
    # Return the Hurst exponent from the polyfit output
    return poly[0] * 2.0

